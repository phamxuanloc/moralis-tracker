# =============================================================================
# Moralis Tracker — Laravel Package .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx

# -----------------------------------------------------------------------------
# PHP / Composer
# -----------------------------------------------------------------------------
/vendor/
composer.lock
.phpunit.result.cache
.phpunit.cache/
coverage/
*.cache

# -----------------------------------------------------------------------------
# Laravel (host app artefacts if tested inside one)
# -----------------------------------------------------------------------------
/bootstrap/cache/
/storage/*.key
/public/hot
/public/storage
/public/mix-manifest.json
/public/build/

# -----------------------------------------------------------------------------
# Node / Frontend (if added later)
# -----------------------------------------------------------------------------
/node_modules/
/npm-debug.log
/yarn-error.log
package-lock.json
yarn.lock
/.pnp
.pnp.js

# -----------------------------------------------------------------------------
# Build & generated output
# -----------------------------------------------------------------------------
*.min.js
*.min.css
/dist/
/build/
/out/

# -----------------------------------------------------------------------------
# Logs & runtime
# -----------------------------------------------------------------------------
*.log
/storage/logs/
/storage/framework/cache/
/storage/framework/sessions/
/storage/framework/views/

# -----------------------------------------------------------------------------
# Test artefacts
# -----------------------------------------------------------------------------
.phpunit.result.cache
coverage/
/tests/coverage/
.psalm/
psalm.xml.bak

# -----------------------------------------------------------------------------
# OS — macOS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon

# -----------------------------------------------------------------------------
# OS — Windows / WSL
# -----------------------------------------------------------------------------
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.stackdump
[Dd]esktop.ini

# -----------------------------------------------------------------------------
# IDEs — VS Code / Windsurf
# -----------------------------------------------------------------------------
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
.windsurf/
*.code-workspace

# -----------------------------------------------------------------------------
# IDEs — JetBrains (PhpStorm, IntelliJ)
# -----------------------------------------------------------------------------
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# -----------------------------------------------------------------------------
# IDEs — Sublime, Vim, Emacs, etc.
# -----------------------------------------------------------------------------
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~
.netrwhist
tags

# -----------------------------------------------------------------------------
# Temporary / debug scripts (keep test-api.php? your call — listed here)
# -----------------------------------------------------------------------------
debug-api.php
check-php.php
