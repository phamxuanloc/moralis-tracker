APP_NAME=MoralisTracker
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=moralis_tracker
DB_USERNAME=root
DB_PASSWORD=

# --------------------------------------------------
# Moralis Tracker
# --------------------------------------------------

# Get your free API key at https://admin.moralis.io/api-keys
MORALIS_API_KEY=

# Moralis API base URL (do not change unless self-hosting)
MORALIS_BASE_URL=https://deep-index.moralis.io/api/v2.2

# BSC Mainnet: bsc | BSC Testnet: 0x61
MORALIS_CHAIN=bsc

# Comma-separated BSC addresses to track (seeded into DB on first boot)
MORALIS_ADDRESSES=

# HTTP timeout in seconds
MORALIS_TIMEOUT=30

# Max retries on failure / rate limit
MORALIS_MAX_RETRIES=3

# Log channel for transaction sync logs (defaults to LOG_CHANNEL)
MORALIS_LOG_CHANNEL=stack
